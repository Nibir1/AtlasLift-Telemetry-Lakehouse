# Purpose: Template for environment variables required for local testing and deployment
# Author: Nahasat Nibir
# Date: 2026-03-14

# Databricks Deployment & Execution
DATABRICKS_HOST=https://adb-<workspace-id>.<random-number>.azuredatabricks.net
DATABRICKS_TOKEN=dapi<your-personal-access-token>
DATABRICKS_CLUSTER_ID=<your-standard-ds3-v2-cluster-id>

# Azure Data Lake Storage (ADLS Gen2)
AZURE_TENANT_ID=<your-azure-tenant-id>
AZURE_CLIENT_ID=<your-service-principal-client-id>
AZURE_CLIENT_SECRET=<your-service-principal-secret>
STORAGE_ACCOUNT_NAME=atlasliftdatalake
STORAGE_CONTAINER_NAME=telemetry-raw

# Pipeline Configuration Defaults
ENVIRONMENT=dev
LOG_LEVEL=INFO